# Copy to server/.env and fill in. server/.env is gitignored — never commit secrets.

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# DigitalOcean Gradient inference — create a model access key in the DO console
# (INFERENCE > Manage > Create model access key). Shown only once.
DIGITAL_OCEAN_MODEL_ACCESS_KEY=
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1

# Model names — verified working on DO as of 2026-07-11; the spike re-confirms.
MODEL_FAST=anthropic-claude-haiku-4.5
MODEL_SMART=anthropic-claude-4.6-sonnet

# Managed Postgres (optional until Phase 1). Use the DO connection string.
DATABASE_URL=

# CORS — comma-separated allowed browser origins (Vite dev server default below).
CORS_ORIGIN=http://localhost:5173

# Phase 4 — optional local static serve (after `npm run build -w client`)
# CLIENT_DIST=../client/dist
# MIGRATIONS_DIR=./src/db/migrations
